<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:padding="6dp">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="40dp"
        android:layout_gravity="center_vertical"
        android:padding="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/card_overlay"
            android:clipToOutline="true"
            >


            <ImageView
                android:id="@+id/rs_event_img"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/dave"
                />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_overlay"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/rsvp_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginVertical="20dp"
                android:layout_marginHorizontal="20dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/rsvp_badge_background"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/bricolagegrotesque_semibold"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="12 RSVPs"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_gravity="bottom">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="15dp">


            <TextView
                android:id="@+id/rs_event_name"
                android:text="This is the title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/bricolagegrotesque_bold"
                android:maxLines="2"/>

            <TextView
                android:id="@+id/rs_event_date"
                android:text="this is date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:fontFamily="@font/bricolagegrotesque_semibold"/>

            <TextView
                android:id="@+id/rs_event_location"
                android:text="This is the location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#888888"
                android:textSize="17sp"
                android:fontFamily="@font/bricolagegrotesque_light"
                android:maxLines="2"/>

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>










