<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.Account_activity"
    android:background="#d1e9ff">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/arrow_left_5_svgrepo_com"
                    android:contentDescription="Back"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Account"
                    android:textColor="@color/black"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/bricolagegrotesque_bold"/>

                <EditText
                    android:id="@+id/surnameField"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/form_field_outline"
                    android:fontFamily="@font/bricolagegrotesque_semibold"
                    android:paddingHorizontal="16dp"
                    android:text="Smith"
                    android:textColor="@color/black"
                    android:textSize="15sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profileImage"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/h"/>

                <TextView
                    android:id="@+id/change_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Change photo"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:fontFamily="@font/bricolagegrotesque_light"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Details"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="@font/bricolagegrotesque_bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NAME"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/nameField"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/form_field_outline"
                        android:paddingHorizontal="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:textColor="@color/black"
                        android:text="Jane"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SURNAME"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USERNAME"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/usernameField"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/form_field_outline"
                        android:paddingHorizontal="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:textColor="@color/black"
                        android:text="janesmith2020"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/emailField"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/form_field_outline"
                        android:paddingHorizontal="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:textColor="@color/black"
                        android:inputType="textEmailAddress"
                        android:text="jane@email.com"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"/>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD"
                        android:textColor="#888888"
                        android:textSize="10sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/passwordField"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/form_field_outline"
                        android:paddingHorizontal="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:textColor="@color/black"
                        android:inputType="textPassword"
                        android:text="password123"
                        android:focusable="false"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/forgotPasswordLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forgot password?"
                        android:textColor="#1a6cbf"
                        android:textSize="12sp"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <Button
                        android:id="@+id/btn_save"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Save Changes"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textAllCaps="false"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:backgroundTint="@color/black"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:fontFamily="@font/bricolagegrotesque_bold"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/form_field_outline"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Log Out"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:fontFamily="@font/bricolagegrotesque_semibold"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">


                    <Button
                        android:id="@+id/btn_delete_account"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Delete Account"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textAllCaps="false"
                        android:fontFamily="@font/bricolagegrotesque_semibold"
                        android:backgroundTint="#e63946"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
  </androidx.coordinatorlayout.widget.CoordinatorLayout>