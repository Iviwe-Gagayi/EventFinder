<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10000000"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <item
        android:left="2dp"
        android:right="2dp"
        android:top="2dp"
        android:bottom="2dp">

        <shape android:shape="rectangle">

            <gradient
                android:type="linear"
                android:angle="225"
                android:startColor="#A8C5DD"
                android:centerColor="#C5DAEA"
                android:endColor="#A8C5DD"/>

            <stroke
                android:width="1dp"
                android:color="#60FFFFFF"/>

            <corners android:radius="25dp"/>

        </shape>
    </item>

</layer-list>